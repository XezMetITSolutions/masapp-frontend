# Ana domain yönlendirmeleri
guzellestir.com/* /:splat 200
www.guzellestir.com/* /:splat 200

# Admin subdomain - admin paneli için
admin.guzellestir.com/ /admin/dashboard 200
admin.guzellestir.com/* /admin/:splat 200

# Restoran subdomain'leri (wildcard)
*.guzellestir.com/* /:splat 200

# HTTP'den HTTPS'e yönlendirme
http://admin.guzellestir.com/* https://admin.guzellestir.com/:splat 301
http://*.guzellestir.com/* https://:splat 301

# Fallback - tüm istekleri ana sayfaya yönlendir
/* /index.html 200